{
  "spin": [
    {"name": "AL_guard_flip_lockState",
     "description": "AcquireLock CAS guard: CanAcquire flip via lockState",
     "pattern": "(CanAcquire\\(t\\) ==.*?)/\\\\ lockState = FALSE",
     "replacement": "\\1/\\\\ lockState = TRUE"},
    {"name": "AL_guard_drop_threadState",
     "description": "AcquireLock: drop threadState in {idle,trying,spinning} guard",
     "pattern": "(AcquireLock\\(t\\) ==.*?)/\\\\ threadState\\[t\\] \\\\in \\{\"idle\", \"trying\", \"spinning\"\\}\\n",
     "replacement": "\\1"},
    {"name": "RL_body_flip_lockState",
     "description": "ReleaseLock body: lockState' = FALSE -> TRUE",
     "pattern": "(ReleaseLock\\(t\\) ==.*?)/\\\\ lockState' = FALSE",
     "replacement": "\\1/\\\\ lockState' = TRUE"},
    {"name": "RL_guard_flip_threadState",
     "description": "ReleaseLock guard: threadState[t]='locked' -> 'idle'",
     "pattern": "(ReleaseLock\\(t\\) ==.*?)/\\\\ threadState\\[t\\] = \"locked\"",
     "replacement": "\\1/\\\\ threadState[t] = \"idle\""},
    {"name": "RL_guard_drop_lockHolder",
     "description": "ReleaseLock: drop 'lockHolder[t] = TRUE' guard",
     "pattern": "(ReleaseLock\\(t\\) ==.*?)/\\\\ lockHolder\\[t\\] = TRUE\\n",
     "replacement": "\\1"},
    {"name": "RL_guard_drop_lockStateTrue",
     "description": "ReleaseLock: drop 'lockState = TRUE' guard",
     "pattern": "(ReleaseLock\\(t\\) ==.*?)/\\\\ lockState = TRUE\\n",
     "replacement": "\\1"}
  ],

  "mutex": [
    {"name": "RL_body_flip_lockState",
     "description": "ReleaseLock body: lockState' = FALSE -> TRUE",
     "pattern": "(ReleaseLock\\(t\\) ==.*?)/\\\\ lockState' = FALSE",
     "replacement": "\\1/\\\\ lockState' = TRUE"},
    {"name": "RL_guard_flip_threadState",
     "description": "ReleaseLock guard: threadState[t] = 'InCS' -> # 'InCS'",
     "pattern": "(ReleaseLock\\(t\\) ==.*?)/\\\\ threadState\\[t\\] = \"InCS\"",
     "replacement": "\\1/\\\\ threadState[t] # \"InCS\""},
    {"name": "RL_guard_drop_lockHolder",
     "description": "ReleaseLock: drop 't = lockHolder' guard",
     "pattern": "(ReleaseLock\\(t\\) ==.*?)/\\\\ t = lockHolder\\n",
     "replacement": "\\1"},
    {"name": "AL_body_flip_lockState",
     "description": "AcquireLock body: lockState' = TRUE -> FALSE",
     "pattern": "(AcquireLock\\(t\\) ==.*?)/\\\\ lockState' = TRUE",
     "replacement": "\\1/\\\\ lockState' = FALSE"},
    {"name": "AL_guard_flip_lockState",
     "description": "AcquireLock guard: lockState = FALSE -> TRUE",
     "pattern": "(AcquireLock\\(t\\) ==.*?)/\\\\ lockState = FALSE\\n",
     "replacement": "\\1/\\\\ lockState = TRUE\\n"},
    {"name": "AL_guard_drop_threadState",
     "description": "AcquireLock: drop 'threadState[t] = Running' guard",
     "pattern": "(AcquireLock\\(t\\) ==.*?)/\\\\ threadState\\[t\\] = \"Running\"\\n",
     "replacement": "\\1"}
  ],

  "locksvc": [
    {"name": "CLR_guard_flip_clientState",
     "description": "ClientLockRequest guard: clientState='idle' -> 'waiting'",
     "pattern": "(ClientLockRequest\\(c\\) ==.*?)/\\\\ clientState\\[c\\] = \"idle\"",
     "replacement": "\\1/\\\\ clientState[c] = \"waiting\""},
    {"name": "SGL_guard_drop_msgType",
     "description": "ServerGrantLock: drop 'serverMsg.type = LockMsg' guard",
     "pattern": "(ServerGrantLock ==.*?)/\\\\ serverMsg\\.type = LockMsg\\n",
     "replacement": "\\1"},
    {"name": "CCS_body_flip_hasLock",
     "description": "ClientCriticalSection body: hasLock' = TRUE -> FALSE",
     "pattern": "(ClientCriticalSection\\(c\\) ==.*?)/\\\\ hasLock' = \\[hasLock EXCEPT !\\[c\\] = TRUE\\]",
     "replacement": "\\1/\\\\ hasLock' = [hasLock EXCEPT ![c] = FALSE]"},
    {"name": "CUR_guard_drop_hasLock",
     "description": "ClientUnlockRequest: drop 'hasLock[c] = TRUE' guard",
     "pattern": "(ClientUnlockRequest\\(c\\) ==.*?)/\\\\ hasLock\\[c\\] = TRUE\\n",
     "replacement": "\\1"},
    {"name": "CUR_guard_flip_clientState",
     "description": "ClientUnlockRequest guard: clientState='critical' -> 'idle'",
     "pattern": "(ClientUnlockRequest\\(c\\) ==.*?)/\\\\ clientState\\[c\\] = \"critical\"",
     "replacement": "\\1/\\\\ clientState[c] = \"idle\""}
  ]
}
